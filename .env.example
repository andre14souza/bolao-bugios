# Configurações do Frontend (Vite)
# Se você hospedar o Frontend e o Backend juntos na mesma máquina/serviço (ex: Render), pode deixar VITE_API_BASE vazio.
# Se você hospedar o Frontend separado (ex: Vercel) e o Backend em outro lugar (ex: Render), defina a URL do seu Backend aqui.
VITE_API_BASE=

# Configurações do Supabase (Opcional - caso queira usar banco na nuvem gratuito ao invés do JSON local)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Configurações do Backend (Node.js)
# Porta na qual o servidor Express vai rodar (injetada automaticamente por plataformas como Render)
PORT=3001

# Caminho para o banco de dados JSON local (Opcional - útil para configurar Discos Persistentes em nuvem)
DB_PATH=
